# =============================================================
# WorkshopOS — Variables de entorno de PRODUCCIÓN
# Copiar como .env y completar todos los valores
# NUNCA commitear el .env real a git
# =============================================================

# ── Base de datos PostgreSQL ──────────────────────────────────
POSTGRES_USER=workshopos_app
POSTGRES_PASSWORD=GENERAR_CON_openssl_rand_hex_20
POSTGRES_DB=workshopos

# URL completa para la app (usa el nombre del servicio Docker 'db')
DATABASE_URL=postgresql+asyncpg://workshopos_app:MISMO_PASSWORD_QUE_ARRIBA@db:5432/workshopos

# ── Seguridad JWT ─────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=GENERAR_CON_openssl_rand_hex_32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────────
# Generar con: openssl rand -hex 20
REDIS_PASSWORD=GENERAR_CON_openssl_rand_hex_20
REDIS_URL=redis://:MISMO_PASSWORD_QUE_ARRIBA@redis:6379/0

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=https://works.conectaai.cl

# ── Entorno ───────────────────────────────────────────────────
# "production" deshabilita /docs y /redoc de FastAPI
ENVIRONMENT=production

# ── Email (Resend) ─────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@conectaai.cl
