# =============================================================
# WorkshopOS Backend — Variables de entorno
# Para desarrollo local: copiar como .env y ajustar valores
# =============================================================

# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://workshopos:workshopos@localhost:5432/workshopos

# ── Seguridad JWT ─────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=  (vacío en local, requerido en producción)

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Entorno ───────────────────────────────────────────────────
# "production" deshabilita /docs, /redoc y /openapi.json
ENVIRONMENT=development

# ── Archivos subidos ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# ── Email (Resend) — opcional ─────────────────────────────────
# Sin RESEND_API_KEY los emails simplemente no se envían (sin error)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=noreply@works.conectaai.cl
# FROM_NAME=WorkshopOS

# ── Workers uvicorn ───────────────────────────────────────────
WORKERS=2
