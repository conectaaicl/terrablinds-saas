FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

# URL relativa (mismo dominio) — .env excluido por .dockerignore así que lo seteamos aquí
ENV VITE_API_URL=
RUN npm run build

# Segunda etapa: imagen mínima solo para extraer el dist/
FROM nginx:1.27-alpine AS runner
COPY --from=builder /app/dist /usr/share/nginx/html
